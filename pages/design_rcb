import streamlit as st

# Configuração da página e título na aba do navegador
st.set_page_config(page_title="RCB Aportes", page_icon="📈", layout="centered")

# --- PASSO 4: ESTILIZAÇÃO CUSTOMIZADA (CORES DA MARCA RCB) ---
# Injetando CSS para fixar os tons de Azul Marinho Escuro e Dourado nos botões e textos
st.markdown(
    """
    <style>
    /* Cor de fundo principal da aplicação */
    .stApp {
        background-color: #031430;
    }
    /* Estilização do título principal serifado */
    .titulo-logo {
        font-family: 'Georgia', serif;
        font-size: 46px;
        font-weight: bold;
        color: #FFFFFF;
        margin-bottom: 0px;
    }
    /* Estilização do subtítulo em dourado */
    .subtitulo-logo {
        font-family: 'Arial', sans-serif;
        font-size: 16px;
        font-weight: bold;
        color: #B59453;
        letter-spacing: 4px;
        margin-top: -10px;
        margin-bottom: 30px;
    }
    /* Customização dos botões para o Dourado da Seta do Logo */
    div.stButton > button:first-child {
        background-color: #B59453;
        color: #031430;
        font-weight: bold;
        border-radius: 8px;
        border: none;
        width: 100%;
        height: 45px;
    }
    div.stButton > button:first-child:hover {
        background-color: #94763E;
        color: #FFFFFF;
    }
    </style>
    """,
    unsafe_replace_html=True
)

# --- 1. CABEÇALHO / LOGO DA MARCA ---
st.markdown('<p class="titulo-logo">RCB</p>', unsafe_replace_html=True)
st.markdown('<p class="subtitulo-logo">APORTES</p>', unsafe_replace_html=True)

# --- 2. CARD DE RESUMO FINANCEIRO ---
# Criando uma caixa visual com fundo azul ligeiramente destacado e borda dourada
st.markdown(
    """
    <div style="background-color: #081F42; padding: 20px; border-radius: 12px; border: 1px solid #B59453; margin-bottom: 25px;">
        <span style="color: #B59453; font-size: 12px; font-weight: bold; letter-spacing: 1px;">TOTAL APORTADO</span>
        <h1 style="color: #FFFFFF; margin: 5px 0 0 0; font-size: 36px;">R$ 150.000,00</h1>
    </div>
    """, 
    unsafe_replace_html=True
)

# --- 3. FORMULÁRIO DE ENTRADA (MÉTRICAS E ENTRADAS) ---
st.markdown("<h3 style='color: #FFFFFF;'>Registrar Novo Aporte</h3>", unsafe_replace_html=True)

# Organizando os campos lado a lado usando colunas
col1, col2 = st.columns([1, 1])

with col1:
    nome_cliente = st.text_input("Identificação do Cliente / Teste:")

with col2:
    valor_aporte = st.number_input("Valor do Aporte (R$):", min_value=0.0, step=100.0)

# --- 4. BOTÃO DE AÇÃO ESTILIZADO ---
if st.button("CONFIRMAR APORTE"):
    if nome_cliente and valor_aporte > 0:
        st.success(f"Aporte de R$ {valor_aporte:,.2f} para o cliente '{nome_cliente}' validado no design!")
    else:
        st.error("Por favor, preencha a identificação e o valor do aporte.")
